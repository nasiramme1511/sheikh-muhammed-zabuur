generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int      @id @default(autoincrement())
  email                String   @unique
  password             String
  name                 String
  role                 Role     @default(USER)
  image                String?
  newsletterSubscribed Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  bookmarks     Bookmark[]
  progress      UserProgress[]
  schedules     Schedule[]
  usageLogs     UsageLog[]
  notifications Notification[]
  chatMessages  ChatMessage[]

  @@index([role])
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

model ScholarProfile {
  id               Int      @id @default(autoincrement())
  name             String
  arabicName       String?
  title            String?
  biography        String?  @db.Text
  shortBiography   String?  @db.Text
  profileImage     String?
  coverImage       String?
  teachingSchedule String?  @db.Text
  qualifications   String?  @db.Text
  areasOfStudy     String?  @db.Text
  yearsActive      Int?
  studentsCount    Int      @default(0)
  resourceCount    Int      @default(0)
  youtubeUrl       String?
  telegramUrl      String?
  facebookUrl      String?
  tiktokUrl        String?
  twitterUrl       String?
  instagramUrl     String?
  websiteUrl       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SiteSettings {
  id               Int     @id @default(autoincrement())
  siteName         String  @default("Iman Chercher College")
  siteDescription  String? @db.Text
  logo             String?
  favicon          String?
  splashScreen     String?
  heroImage        String?
  socialShareImage String?
  dashboardBanner  String?
  appleTouchIcon   String?
  pwaMaskableIcon  String?
  contactEmail     String?
  phone            String?
  address          String? @db.Text
  copyrightText    String?
  defaultLanguage  String  @default("en")
  maintenanceMode  Boolean @default(false)
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  nameAmharic String?
  nameArabic  String?
  nameOromic  String?
  slug        String   @unique
  description String?  @db.Text
  descriptionAmharic String?  @db.Text
  descriptionArabic  String?  @db.Text
  descriptionOromic  String?  @db.Text
  image       String?
  icon        String?
  color       String?
  order       Int      @default(0)
  isBeginner  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  books   Book[]
  lessons Lesson[]
  courses Course[]

  @@index([slug])
  @@index([order])
}

model Book {
  id          Int      @id @default(autoincrement())
  title       String
  titleAmharic String?
  titleArabic String?
  titleOromic String?
  slug        String   @unique
  description String?  @db.Text
  descriptionAmharic String?  @db.Text
  descriptionArabic  String?  @db.Text
  descriptionOromic  String?  @db.Text
  author      String?
  pdfUrl      String?
  pdfUrlAr    String?
  pdfUrlAm    String?
  pdfUrlOm    String?
  coverImage  String?
  coverImageAr String?
  coverImageAm String?
  coverImageOm String?
  categoryId  Int?
  isBeginner  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category  Category?  @relation(fields: [categoryId], references: [id])
  lessons   Lesson[]
  resources Resource[]

  @@index([slug])
  @@index([categoryId])
}

model Level {
  id          Int      @id @default(autoincrement())
  name        String
  nameAmharic String?
  nameArabic  String?
  nameOromic  String?
  slug        String   @unique
  description String?
  descriptionAmharic String?
  descriptionArabic  String?
  descriptionOromic  String?
  order       Int      @default(0)
  icon        String?
  color       String?
  createdAt   DateTime @default(now())

  lessons Lesson[]
  courses Course[]

  @@index([slug])
  @@index([order])
}

model Course {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  thumbnail   String?
  description String?  @db.Text
  categoryId  Int?
  levelId     Int?
  language    String   @default("en")
  duration    Int?
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category      Category?      @relation(fields: [categoryId], references: [id])
  level         Level?         @relation(fields: [levelId], references: [id])
  lessons       Lesson[]
  announcements Announcement[]

  @@index([slug])
  @@index([status])
}

model Lesson {
  id          Int      @id @default(autoincrement())
  title       String
  titleAmharic String?
  titleArabic String?
  titleOromic String?
  slug        String   @unique
  description String?  @db.Text
  descriptionAmharic String?  @db.Text
  descriptionArabic  String?  @db.Text
  descriptionOromic  String?  @db.Text
  audioUrl    String
  pdfUrl      String?
  videoUrl    String?
  transcript  String?  @db.Text
  notes       String?  @db.Text
  duration    Int?
  episodeNumber Int?
  categoryId  Int?
  bookId      Int?
  levelId     Int?
  courseId    Int?
  difficulty  String   @default("beginner")
  isBeginner  Boolean  @default(false)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category  Category?   @relation(fields: [categoryId], references: [id])
  book      Book?       @relation(fields: [bookId], references: [id])
  level     Level?      @relation(fields: [levelId], references: [id])
  course    Course?     @relation(fields: [courseId], references: [id], onDelete: SetNull)
  bookmarks Bookmark[]
  progress  UserProgress[]
  schedules Schedule[]

  @@index([slug])
  @@index([categoryId])
  @@index([levelId])
  @@index([courseId])
  @@index([published])
  @@index([isBeginner])
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  userId    Int
  lessonId  Int
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model UserProgress {
  id        Int      @id @default(autoincrement())
  userId    Int
  lessonId  Int
  position  Float    @default(0)
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model Schedule {
  id        Int      @id @default(autoincrement())
  userId    Int
  lessonId  Int
  dayOfWeek Int?
  time      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UsageLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  metadata  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

enum ResourceType {
  PDF
  AUDIO
  VIDEO
  IMAGE
}

model Resource {
  id           Int          @id @default(autoincrement())
  title        String
  description  String?      @db.Text
  category     String
  collection   String?
  language     String       @default("en")
  author       String?
  bookId       Int?
  fileType     String       @default("pdf")
  resourceType ResourceType @default(PDF)
  fileUrl      String
  fileHash     String?
  thumbnail    String?
  downloads    Int          @default(0)
  views        Int          @default(0)
  featured     Boolean      @default(false)
  published    Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  book         Book?        @relation(fields: [bookId], references: [id], onDelete: SetNull)

  @@index([resourceType])
  @@index([category])
  @@index([collection])
  @@index([language])
  @@index([featured])
  @@index([published])
  @@index([downloads])
  @@index([views])
}

model Announcement {
  id        Int      @id @default(autoincrement())
  courseId  Int?
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())

  course    Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

model TelegramChannel {
  id          Int      @id @default(autoincrement())
  name        String
  link        String
  teacherName String?
  description String?
  category    String   @default("General")
  enabled     Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled])
  @@index([category])
}

model Subscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  language  String   @default("en")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active])
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int?
  sessionId String
  role      String
  content   String
  language  String   @default("en")
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
}
