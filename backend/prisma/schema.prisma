generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int      @id @default(autoincrement())
  email                String   @unique
  password             String
  name                 String
  role                 Role     @default(USER)
  image                String?
  newsletterSubscribed Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  chatMessages ChatMessage[]
  usageLogs    UsageLog[]

  @@index([role])
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

model ScholarProfile {
  id               Int      @id @default(autoincrement())
  name             String
  arabicName       String?
  title            String?
  biography        String?  @db.Text
  shortBiography   String?  @db.Text
  profileImage     String?
  coverImage       String?
  teachingSchedule String?  @db.Text
  qualifications   String?  @db.Text
  areasOfStudy     String?  @db.Text
  yearsActive      Int?
  studentsCount    Int      @default(0)
  resourceCount    Int      @default(0)
  youtubeUrl       String?
  telegramUrl      String?
  facebookUrl      String?
  tiktokUrl        String?
  twitterUrl       String?
  instagramUrl     String?
  websiteUrl       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SiteSettings {
  id              Int     @id @default(autoincrement())
  siteName        String  @default("Sheikh Mohammed Zabuur Official Platform")
  siteDescription String? @db.Text
  logo            String?
  favicon         String?
  telegramLink    String?
  youtubeLink     String?
  facebookLink    String?
  googleMapEmbed  String?
  googleMapLink   String?
  contactEmail    String?
  phone           String?
  address         String? @db.Text
  copyrightText   String?
  defaultLanguage String  @default("en")
  maintenanceMode Boolean @default(false)
}

model LiveStream {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  @db.Text
  streamUrl   String?
  platform    String   @default("youtube")
  isLive      Boolean  @default(false)
  viewerCount Int      @default(0)
  scheduledAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LiveRecording {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  @db.Text
  videoUrl    String
  thumbnail   String?
  recordedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Series {
  id          Int      @id @default(autoincrement())
  name        String
  nameAmharic String?
  nameArabic  String?
  nameOromic  String?
  slug        String   @unique
  description String?  @db.Text
  descriptionAmharic String?  @db.Text
  descriptionArabic  String?  @db.Text
  descriptionOromic  String?  @db.Text
  image       String?
  icon        String?
  color       String?
  order       Int      @default(0)
  totalLessons Int     @default(0)
  totalHours  Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lessons      Lesson[]
  audioLessons AudioLesson[]
  videoLessons VideoLesson[]
  resources    Resource[]

  @@index([slug])
  @@index([order])
}

model AudioLesson {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  description String?  @db.Text
  audioUrl    String
  thumbnail   String?
  duration    Int?
  seriesId    Int?
  downloads   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  series Series? @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([seriesId])
}

model VideoLesson {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  description String?  @db.Text
  videoUrl    String
  thumbnail   String?
  duration    Int?
  seriesId    Int?
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  series Series? @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([seriesId])
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  nameAmharic String?
  nameArabic  String?
  nameOromic  String?
  slug        String   @unique
  description String?  @db.Text
  descriptionAmharic String?  @db.Text
  descriptionArabic  String?  @db.Text
  descriptionOromic  String?  @db.Text
  image       String?
  icon        String?
  color       String?
  order       Int      @default(0)
  isBeginner  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  books   Book[]

  @@index([slug])
  @@index([order])
}

model Book {
  id          Int      @id @default(autoincrement())
  title       String
  titleAmharic String?
  titleArabic String?
  titleOromic String?
  slug        String   @unique
  description String?  @db.Text
  descriptionAmharic String?  @db.Text
  descriptionArabic  String?  @db.Text
  descriptionOromic  String?  @db.Text
  author      String?
  pdfUrl      String?
  pdfUrlAr    String?
  pdfUrlAm    String?
  pdfUrlOm    String?
  coverImage  String?
  coverImageAr String?
  coverImageAm String?
  coverImageOm String?
  categoryId  Int?
  isBeginner  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category  Category?  @relation(fields: [categoryId], references: [id])
  resources Resource[]

  @@index([slug])
  @@index([categoryId])
}

model Lesson {
  id           Int      @id @default(autoincrement())
  title        String
  slug         String   @unique
  description  String?  @db.Text
  audioUrl     String
  videoUrl     String?
  duration     Int?
  episodeNumber Int?
  seriesId     Int?
  published    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  series Series? @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([seriesId])
  @@index([published])
}



enum ResourceType {
  PDF
  AUDIO
  VIDEO
  IMAGE
}

model Resource {
  id           Int          @id @default(autoincrement())
  title        String
  description  String?      @db.Text
  category     String
  collection   String?
  language     String       @default("en")
  author       String?
  bookId       Int?
  fileType     String       @default("pdf")
  resourceType ResourceType @default(PDF)
  fileUrl      String
  fileHash     String?
  thumbnail    String?
  downloads    Int          @default(0)
  views        Int          @default(0)
  featured     Boolean      @default(false)
  published    Boolean      @default(true)
  deletedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  book         Book?        @relation(fields: [bookId], references: [id], onDelete: SetNull)
  seriesId     Int?
  series       Series?      @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  @@index([resourceType])
  @@index([category])
  @@index([collection])
  @@index([language])
  @@index([featured])
  @@index([published])
  @@index([deletedAt])
  @@index([downloads])
  @@index([views])
  @@index([seriesId])
}

model TelegramChannel {
  id          Int      @id @default(autoincrement())
  name        String
  link        String
  teacherName String?
  description String?
  category    String   @default("General")
  enabled     Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled])
  @@index([category])
}

model Subscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  language  String   @default("en")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active])
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int?
  sessionId String
  role      String
  content   String
  language  String   @default("en")
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
}

model UsageLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  metadata  String?  @db.Text
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
